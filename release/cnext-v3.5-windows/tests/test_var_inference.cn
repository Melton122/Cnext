// Test var type inference and for-in with var

// EXPECT: Hello, Cnext! You are 25 years old.
// EXPECT: 85
// EXPECT: 90
// EXPECT: 95

main {
    var name = "Cnext"
    var age = 25
    printin("Hello, {name}! You are {age} years old.")
    
    int[] scores = {85, 90, 95}
    for var item in scores {
        printin(item)
    }
}
