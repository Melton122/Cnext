// Test optimizer features: constant folding, identity elimination

test "constant folding" {
    // These should be evaluated at compile time
    int x = 2 + 3
    assert(x == 5)
    
    int y = 10 * 2
    assert(y == 20)
    
    int z = 100 / 4
    assert(z == 25)
    
    println("constant folding: OK")
}

test "identity elimination" {
    // x + 0 -> x
    int a = 5 + 0
    assert(a == 5)
    
    // 0 + x -> x
    int b = 0 + 10
    assert(b == 10)
    
    // x * 1 -> x
    int c = 7 * 1
    assert(c == 7)
    
    // 1 * x -> x
    int d = 1 * 9
    assert(d == 9)
    
    // x - 0 -> x
    int e = 15 - 0
    assert(e == 15)
    
    // x * 0 -> 0
    int f = 100 * 0
    assert(f == 0)
    
    // 0 * x -> 0
    int g = 0 * 999
    assert(g == 0)
    
    println("identity elimination: OK")
}

test "boolean folding" {
    // Comparisons with constants
    assert(5 == 5)
    assert(5 != 3)
    assert(5 > 3)
    assert(3 < 5)
    assert(5 >= 5)
    assert(5 <= 5)
    
    // Boolean constants
    assert(true)
    assert(!false)
    
    println("boolean folding: OK")
}

test "unary folding" {
    int x = -5
    assert(x == -5)
    
    bool y = !false
    assert(y == true)
    
    println("unary folding: OK")
}

test "nested constant expressions" {
    int x = (2 + 3) * 4
    assert(x == 20)
    
    int y = 100 / (5 + 5)
    assert(y == 10)
    
    println("nested constants: OK")
}

main {
    println("All optimizer tests passed!")
}
