// EXPECT: Testing lambdas...
// EXPECT: add(10, 20) = 30
// EXPECT: double_it(15) = 30
main {
    printin("Testing lambdas...")
    
    var add = (int a, int b) => a + b
    var val = add(10, 20)
    printin("add(10, 20) = " + val)
    
    var double_it = (int x) => {
        return x * 2
    }
    printin("double_it(15) = " + double_it(15))
}
