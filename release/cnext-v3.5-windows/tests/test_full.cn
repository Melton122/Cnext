// Test all features combined

// EXPECT: 10
// EXPECT: 50
// EXPECT: 1
// EXPECT: 2
// EXPECT: 15
// EXPECT: Green

enum Color {
    RED,
    GREEN,
    BLUE
}

struct Point {
    int x
    int y
}

struct Rect {
    int width
    int height
}

func area(Rect r) -> int {
    return r.width * r.height
}

main {
    const int max_size = 100

    Point p
    p.x = 10
    p.y = 20
    printin(p.x)

    Rect rect
    rect.width = 5
    rect.height = 10
    printin(area(rect))

    int[] nums = {1, 2, 3, 4, 5}
    for var n in nums {
        if n == 3 {
            continue
        }
        if n == 4 {
            break
        }
        printin(n)
    }

    int sum = 0
    for int i = 0; i < nums.length; i = i + 1 {
        sum = sum + nums[i]
    }
    printin(sum)

    Color c = GREEN
    switch c {
        case RED:
            printin("Red")
        case GREEN:
            printin("Green")
        case BLUE:
            printin("Blue")
        default:
            printin("Unknown")
    }
}
