// EXPECT: Testing try/catch...
// EXPECT: Inside try...
// EXPECT: Caught error: This is an error
// EXPECT: Finally block executed
// EXPECT: Test passed
main {
    printin("Testing try/catch...");
    
    bool caught = false;
    
    try {
        printin("Inside try...");
        throw "This is an error";
        printin("This should not be reached");
    } catch (str error) {
        printin("Caught error: " + error);
        caught = true;
    } finally {
        printin("Finally block executed");
    }
    
    if (caught) {
        printin("Test passed");
    } else {
        printin("Test failed");
    }
}
