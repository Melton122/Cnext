// EXPECT: true
// EXPECT: Hello from Cnext IO!
// EXPECT: true
// EXPECT: Hello from Cnext IO!
// EXPECT: Appended line.
import io

main {
    str content = "Hello from Cnext IO!"
    bool written = write_file("test_output.txt", content)
    printin(written)

    str read_back = read_file("test_output.txt")
    printin(read_back)

    bool appended = append_file("test_output.txt", "\nAppended line.")
    printin(appended)

    str read_again = read_file("test_output.txt")
    printin(read_again)
}
