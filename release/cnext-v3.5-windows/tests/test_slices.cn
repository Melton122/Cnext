main {
    int[] arr = {0, 10, 20, 30, 40}

    int[] slice1 = arr[1:4]
    printin(slice1.length == 3)
    printin(slice1[0] == 10)
    printin(slice1[1] == 20)
    printin(slice1[2] == 30)

    int[] slice2 = arr[2:]
    printin(slice2.length == 3)
    printin(slice2[0] == 20)

    int[] slice3 = arr[:3]
    printin(slice3.length == 3)
    printin(slice3[0] == 0)
    printin(slice3[2] == 20)

    int[] slice4 = arr[:]
    printin(slice4.length == 5)
    printin(slice4[0] == 0)
    printin(slice4[4] == 40)
}
