// === Comprehensive Closure Tests ===
// Tests: basic capture, reference mutation, multiple captures, nested scopes,
//        closures with strings, closures in loops, non-capturing lambdas

// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1

main {
    // --- Test 1: Basic single capture ---
    var x = 10
    var add_x = (int a) => a + x
    printin(add_x(5) == 15)

    // --- Test 2: Multiple captures ---
    var y = 20
    var add_xy = (int a) => a + x + y
    printin(add_xy(5) == 35)

    // --- Test 3: Non-capturing lambda (backward compat) ---
    var add = (int a, int b) => a + b
    printin(add(10, 20) == 30)

    // --- Test 4: Multiple closures same variable ---
    var double_x = (int a) => a + x
    var triple_x = (int a) => a + x + x
    printin(double_x(1) == 11)
    printin(triple_x(1) == 21)

    // --- Test 5: Reference mutation (key test) ---
    var counter = 0
    var increment = (int n) => {
        counter = counter + n
        return counter
    }
    printin(increment(5) == 5)
    printin(increment(3) == 8)

    // --- Test 6: Closure with string capture ---
    var greeting = "hello"
    var greet = (str name) => {
        return greeting + " " + name
    }
    var result = greet("world")
    printin(result.length == 11)

    // --- Test 7: Closures in nested scope ---
    var multiplier = 3
    var result2 = 0
    if (true) {
        var times = (int n) => n * multiplier
        result2 = times(7)
    }
    printin(result2 == 21)

    // --- Test 8: Closure capturing and mutating in nested scope ---
    var outer_val = 100
    var mutate_outer = (int delta) => {
        outer_val = outer_val + delta
        return outer_val
    }
    printin(mutate_outer(50) == 150)
    printin(mutate_outer(-20) == 130)

    // --- Test 9: Multiple closures sharing mutation ---
    var shared = 0
    var inc_shared = (int dummy) => {
        shared = shared + 1
        return shared
    }
    var dec_shared = (int dummy) => {
        shared = shared - 1
        return shared
    }
    printin(inc_shared(0) == 1)
    printin(inc_shared(0) == 2)
    printin(dec_shared(0) == 1)
    printin(inc_shared(0) == 2)
}
