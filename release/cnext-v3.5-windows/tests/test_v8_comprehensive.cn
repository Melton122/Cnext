// Cnext v8.0 Comprehensive Test Suite

// EXPECT: 42
// EXPECT: 9999999999
// EXPECT: 3.140000
// EXPECT: Cnext
// EXPECT: true
// EXPECT: A
// EXPECT: 255
// EXPECT: 4294967295
// EXPECT: 65535
// EXPECT: 255
// EXPECT: 7
// EXPECT: Hello, World!
// EXPECT: 55
// EXPECT: zero
// EXPECT: many
// EXPECT: 1
// EXPECT: 2
// EXPECT: 3
// EXPECT: Division by zero
// EXPECT: 5

main {
    // Test 1: Basic types
    int x = 42
    printin(x)
    
    long big = 9999999999
    printin(big)
    
    float pi = 3.14
    printin(pi)
    
    str name = "Cnext"
    printin(name)
    
    bool flag = true
    printin(flag)
    
    char letter = 'A'
    printin(letter)
    
    byte small = 255
    printin(small)
    
    // Test 2: Unsigned types
    uint unsigned_val = 4294967295
    printin(unsigned_val)
    
    ushort small_uint = 65535
    printin(small_uint)
    
    ubyte tiny = 255
    printin(tiny)
    
    // Test 3: Functions
    func add(int a, int b) -> int {
        return a + b
    }
    
    func greet(str n) -> str {
        return "Hello, " + n + "!"
    }
    
    printin(add(3, 4))
    printin(greet("World"))
    
    // Test 4: Control flow
    int sum = 0
    for int i = 1; i <= 10; i = i + 1 {
        sum = sum + i
    }
    printin(sum)
    
    // Test 5: Pattern matching
    func describe(int v) -> str {
        match v {
            0 => "zero"
            1 => "one"
            _ => "many"
        }
    }
    
    printin(describe(0))
    printin(describe(5))
    
    // Test 6: Closures
    var counter = 0
    var increment = () => {
        counter = counter + 1
        return counter
    }
    
    printin(increment())
    printin(increment())
    printin(increment())
    
    // Test 7: Try/catch
    func divide(int a, int b) -> int {
        if b == 0 {
            throw "Division by zero"
        }
        return a / b
    }
    
    try {
        var result = divide(10, 0)
        printin(result)
    } catch (str err) {
        printin(err)
    }
    
    // Test 8: Arrays
    int[] numbers = {1, 2, 3, 4, 5}
    printin(numbers[4])
}
