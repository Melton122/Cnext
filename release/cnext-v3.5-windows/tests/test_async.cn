// === Async/Await Tests ===

// EXPECT: 42
// EXPECT: 10
// EXPECT: 10
// EXPECT: 20

// Test 1: Simple async function
async func simple_async() -> int {
    return 42
}

// Test 2: Async function with computation
async func compute_async(int x) -> int {
    var result = x * 2
    return result
}

// Test 3: Multiple async calls
async func add_async(int a, int b) -> int {
    return a + b
}

// Test 4: Async function calling another async function
async func nested_async(int x) -> int {
    var doubled = await compute_async(x)
    var added = await add_async(doubled, 10)
    return added
}

main {
    // Test 1
    printin(await simple_async())

    // Test 2
    printin(await compute_async(5))

    // Test 3
    printin(await add_async(3, 7))

    // Test 4
    printin(await nested_async(5))
}
