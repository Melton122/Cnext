// EXPECT: 5d41402abc4b2a76b9719d911017c592
// EXPECT: 2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824
// EXPECT: aGVsbG8=
// EXPECT: hello
import crypto

main {
    str md5 = crypto_md5("hello")
    printin(md5)

    str sha = crypto_sha256("hello")
    printin(sha)

    str enc = crypto_base64_encode("hello")
    printin(enc)

    str dec = crypto_base64_decode(enc)
    printin(dec)
}
