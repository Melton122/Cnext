// === Comprehensive Generator/Iterator Tests ===

// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1

// Test 1: Simple parameterized generator
func count_to(int n) -> iter<int> {
    var i = 1
    while i <= n {
        yield i
        i = i + 1
    }
}

// Test 2: Parameterless generator
func fibonacci() -> iter<int> {
    var a = 0
    var b = 1
    var count = 0
    while count < 8 {
        yield a
        var temp = a + b
        a = b
        b = temp
        count = count + 1
    }
}

// Test 3: Multiple parameters
func range_gen(int start, int end) -> iter<int> {
    var i = start
    while i < end {
        yield i
        i = i + 1
    }
}

// Test 4: Single yield
func always_42() -> iter<int> {
    yield 42
}

// Test 5: Generator with conditional
func positive_only(int a, int b) -> iter<int> {
    if a > 0 {
        yield a
    }
    if b > 0 {
        yield b
    }
}

// Test 6: Multiple local variables
func multi_var_gen(int n) -> iter<int> {
    var a = 0
    var b = 1
    var i = 0
    while i < n {
        var result = a + b
        yield result
        a = b
        b = result
        i = i + 1
    }
}

main {
    // Test 1: count_to(5) = 1+2+3+4+5 = 15
    var sum1 = 0
    for var x in count_to(5) {
        sum1 = sum1 + x
    }
    printin(sum1 == 15)

    // Test 2: fibonacci first 8 = 0+1+1+2+3+5+8+13 = 33
    var sum2 = 0
    for var x in fibonacci() {
        sum2 = sum2 + x
    }
    printin(sum2 == 33)

    // Test 3: range_gen(3, 7) = 3+4+5+6 = 18
    var sum3 = 0
    for var x in range_gen(3, 7) {
        sum3 = sum3 + x
    }
    printin(sum3 == 18)

    // Test 4: Single yield = 42
    var val4 = 0
    for var x in always_42() {
        val4 = val4 + x
    }
    printin(val4 == 42)

    // Test 5: positive_only(5, -1) = 5
    var sum5 = 0
    for var x in positive_only(5, -1) {
        sum5 = sum5 + x
    }
    printin(sum5 == 5)

    // Test 6: positive_only(-3, 7) = 7
    var sum6 = 0
    for var x in positive_only(-3, 7) {
        sum6 = sum6 + x
    }
    printin(sum6 == 7)

    // Test 7: positive_only(2, 8) = 2+8 = 10
    var sum7 = 0
    for var x in positive_only(2, 8) {
        sum7 = sum7 + x
    }
    printin(sum7 == 10)

    // Test 8: multi_var_gen(4) = 1+2+3+5 = 11
    var sum8 = 0
    for var x in multi_var_gen(4) {
        sum8 = sum8 + x
    }
    printin(sum8 == 11)
}
