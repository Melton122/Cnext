main {
    printin("Hello from Cnext v8.0!")
    
    // Test basic types
    int x = 42
    printin(x)
    
    long big = 9999999999
    printin(big)
    
    float pi = 3.14
    printin(pi)
    
    str name = "Cnext"
    printin(name)
    
    bool flag = true
    printin(flag)
    
    char letter = 'A'
    printin(letter)
    
    byte small = 255
    printin(small)
    
    // Test functions
    func add(int a, int b) -> int {
        return a + b
    }
    
    func greet(str n) -> str {
        return "Hello, " + n + "!"
    }
    
    printin(add(3, 4))
    printin(greet("World"))
    
    // Test control flow
    int sum = 0
    for int i = 1; i <= 10; i = i + 1 {
        sum = sum + i
    }
    printin(sum)
    
    // Test pattern matching
    func describe(int v) -> str {
        match v {
            0 => "zero"
            1 => "one"
            _ => "many"
        }
    }
    
    printin(describe(0))
    printin(describe(5))
    
    // Test closures
    var counter = 0
    var increment = () => {
        counter = counter + 1
        return counter
    }
    
    printin(increment())
    printin(increment())
    printin(increment())
    
    // Test try/catch
    func divide(int a, int b) -> int {
        if b == 0 {
            throw "Division by zero"
        }
        return a / b
    }
    
    try {
        var result = divide(10, 2)
        printin(result)
    } catch (str err) {
        printin(err)
    }
    
    // Test arrays
    int[] numbers = {1, 2, 3, 4, 5}
    printin(numbers[0])
    printin(numbers[4])
    
    printin("All tests passed!")
}
