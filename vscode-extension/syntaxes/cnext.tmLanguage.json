{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cnext",
  "scopeName": "source.cnext",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cnext",
          "match": "//.*$"
        },
        {
          "name": "comment.block.cnext",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cnext",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cnext",
              "match": "\\\\(?:[\"\\\\nrt]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4})"
            },
            {
              "name": "variable.other.interpolated.cnext",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "source.cnext" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.cnext",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cnext",
              "match": "\\\\(?:['\\\\nrt]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cnext",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.cnext",
          "match": "\\b\\d+[eE][+-]?\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.cnext",
          "match": "\\b\\d+\\b"
        },
        {
          "name": "constant.numeric.hex.cnext",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cnext",
          "match": "\\b(if|else|while|for|switch|case|default|break|continue|return|yield|match|throw|try|catch|finally)\\b"
        },
        {
          "name": "keyword.declaration.cnext",
          "match": "\\b(var|const|func|class|struct|enum|interface|trait|import|extends|implements|override|new|super|this|extern)\\b"
        },
        {
          "name": "keyword.other.cnext",
          "match": "\\b(main|test|assert|typeof|as|in|is|null|true|false|constexpr|own)\\b"
        },
        {
          "name": "keyword.coroutine.cnext",
          "match": "\\b(coroutine|resume|with)\\b"
        },
        {
          "name": "keyword.threading.cnext",
          "match": "\\b(thread|spawn|mutex|channel|lock|unlock|send|recv)\\b"
        },
        {
          "name": "keyword.async.cnext",
          "match": "\\b(async|await|run_async)\\b"
        },
        {
          "name": "keyword.threading.cnext",
          "match": "\\b(thread|spawn|mutex|channel|lock|unlock|send|recv)\\b"
        },
        {
          "name": "keyword.operator.declaration.cnext",
          "match": "\\b(operator|extend|macro|bench)\\b"
        },
        {
          "name": "storage.type.attribute.cnext",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.cnext",
          "match": "\\b(int|long|float|double|str|bool|char|byte|void|uint|ulong|ushort|ubyte|short)\\b"
        },
        {
          "name": "support.type.iter.cnext",
          "match": "\\b(iter|Option|Result)\\b"
        },
        {
          "name": "entity.name.type.class.cnext",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.cnext",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.cnext",
          "match": "\\b(printin|input|free|assert)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "variable.language.self.cnext",
          "match": "\\b(self|this)\\b"
        },
        {
          "name": "constant.language.cnext",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.cnext",
          "match": "\\+|-|\\*|/|%|\\+\\+|--"
        },
        {
          "name": "keyword.operator.assignment.cnext",
          "match": "=|\\+=|-=|\\*=|/="
        },
        {
          "name": "keyword.operator.comparison.cnext",
          "match": "==|!=|<|>|<=|>="
        },
        {
          "name": "keyword.operator.logical.cnext",
          "match": "&&|\\||!"
        },
        {
          "name": "keyword.operator.null.cnext",
          "match": "\\?\\?|\\?\\.|\\?"
        },
        {
          "name": "keyword.operator.arrow.cnext",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.ffi.cnext",
          "match": "\\$"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.begin.cnext",
          "match": "\\{"
        },
        {
          "name": "punctuation.definition.block.end.cnext",
          "match": "\\}"
        },
        {
          "name": "punctuation.definition.parameters.begin.cnext",
          "match": "\\("
        },
        {
          "name": "punctuation.definition.parameters.end.cnext",
          "match": "\\)"
        },
        {
          "name": "punctuation.definition.array.begin.cnext",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.array.end.cnext",
          "match": "\\]"
        },
        {
          "name": "punctuation.terminator.cnext",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.cnext",
          "match": ","
        },
        {
          "name": "punctuation.accessor.cnext",
          "match": "\\."
        }
      ]
    }
  }
}
