{
  "name": "cnext",
  "displayName": "Cnext Language Support",
  "description": "Syntax highlighting, snippets, linting, formatting, and build tasks for the Cnext programming language",
  "version": "3.1.0",
  "publisher": "cnext-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "cnext",
    "language",
    "transpiler",
    "compiler",
    "programming language"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cnext",
        "aliases": [
          "Cnext",
          "cnext"
        ],
        "extensions": [
          ".cn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cnext",
        "scopeName": "source.cnext",
        "path": "./syntaxes/cnext.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cnext",
        "path": "./snippets/cnext.json"
      }
    ],
    "commands": [
      {
        "command": "cnext.run",
        "title": "Cnext: Run File",
        "icon": "$(play)"
      },
      {
        "command": "cnext.build",
        "title": "Cnext: Build File",
        "icon": "$(tools)"
      },
      {
        "command": "cnext.buildRelease",
        "title": "Cnext: Build Release",
        "icon": "$(package)"
      },
      {
        "command": "cnext.test",
        "title": "Cnext: Run Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "cnext.format",
        "title": "Cnext: Format File",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "cnext.lint",
        "title": "Cnext: Lint File",
        "icon": "$(alert)"
      },
      {
        "command": "cnext.newProject",
        "title": "Cnext: New Project",
        "icon": "$(add)"
      },
      {
        "command": "cnext.doctor",
        "title": "Cnext: Doctor (Check Environment)",
        "icon": "$(pulse)"
      },
      {
        "command": "cnext.repl",
        "title": "Cnext: Start REPL",
        "icon": "$(terminal)"
      }
    ],
    "keybindings": [
      {
        "command": "cnext.run",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorLangId == cnext"
      },
      {
        "command": "cnext.build",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorLangId == cnext"
      },
      {
        "command": "cnext.test",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorLangId == cnext"
      },
      {
        "command": "cnext.format",
        "key": "shift+alt+f",
        "mac": "shift+cmd+f",
        "when": "editorLangId == cnext"
      }
    ],
    "taskDefinitions": [
      {
        "type": "cnext",
        "properties": {
          "command": {
            "type": "string",
            "description": "Cnext command to run"
          },
          "file": {
            "type": "string",
            "description": "File to process"
          }
        },
        "required": [
          "command"
        ]
      }
    ],
    "configuration": {
      "title": "Cnext",
      "properties": {
        "cnext.compilerPath": {
          "type": "string",
          "default": "cnext",
          "description": "Path to the Cnext compiler"
        },
        "cnext.autoRun": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run file after save"
        },
        "cnext.autoFormat": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format file after save"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo 'No build step needed'"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Melton122/cnext"
  },
  "bugs": {
    "url": "https://github.com/Melton122/cnext/issues"
  },
  "homepage": "https://github.com/Melton122/cnext#readme"
}
