// HTTP Example

import net

main {
    // Simple GET request
    str response = http_get("https://httpbin.org/get")
    printin("Response length: " + response.length)

    // POST request
    var data = '{"name": "Alice"}'
    str result = http_post("https://httpbin.org/post", data)
    printin("POST result length: " + result.length)
}
