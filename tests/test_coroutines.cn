// === Coroutine Tests ===

// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1

// Test 1: Basic coroutine with yield
coroutine func count_to(int n) -> iter<int> {
    var i = 1
    while i <= n {
        yield i
        i = i + 1
    }
}

// Test 2: Coroutine that receives values
coroutine func doubler() -> iter<int> {
    var val = 1
    while true {
        yield val
        val = val * 2
    }
}

// Test 3: Coroutine with conditional yields
coroutine func filter_positive(int a, int b) -> iter<int> {
    if a > 0 {
        yield a
    }
    if b > 0 {
        yield b
    }
}

// Test 4: Single yield coroutine
coroutine func just_42() -> iter<int> {
    yield 42
}

// Test 5: Coroutine with complex logic
coroutine func fibonacci_gen() -> iter<int> {
    var a = 0
    var b = 1
    var count = 0
    while count < 6 {
        yield a
        var temp = a + b
        a = b
        b = temp
        count = count + 1
    }
}

main {
    // Test 1: count_to(5) sum = 15
    var sum1 = 0
    for var x in count_to(5) {
        sum1 = sum1 + x
    }
    printin(sum1 == 15)

    // Test 2: doubler first 4 values = 1+2+4+8 = 15
    var sum2 = 0
    var count2 = 0
    for var x in doubler() {
        sum2 = sum2 + x
        count2 = count2 + 1
        if count2 == 4 {
            break
        }
    }
    printin(sum2 == 15)

    // Test 3: filter_positive(3, -1) = 3
    var sum3 = 0
    for var x in filter_positive(3, -1) {
        sum3 = sum3 + x
    }
    printin(sum3 == 3)

    // Test 4: just_42 = 42
    var val4 = 0
    for var x in just_42() {
        val4 = val4 + x
    }
    printin(val4 == 42)

    // Test 5: fibonacci first 6 = 0+1+1+2+3+5 = 12
    var sum5 = 0
    for var x in fibonacci_gen() {
        sum5 = sum5 + x
    }
    printin(sum5 == 12)
}
