// Test new primitive types: long, double, byte, uint, ulong, ushort, ubyte

test "long type" {
    long x = 9999999999
    assert(x > 0)
    println("long: " + str(x))
}

test "double type" {
    double pi = 3.14159265358979
    assert(pi > 3.0)
    println("double: " + str(pi))
}

test "byte type" {
    byte b = 42
    assert(b == 42)
    println("byte: " + str(b))
}

test "uint type" {
    uint u = 4294967295
    assert(u > 0)
    println("uint: " + str(u))
}

test "ushort type" {
    ushort us = 65535
    assert(us > 0)
    println("ushort: " + str(us))
}

test "ubyte type" {
    ubyte ub = 255
    assert(ub == 255)
    println("ubyte: " + str(ub))
}

test "type arithmetic" {
    int a = 10
    long b = 20
    long c = a + b
    assert(c == 30)
    println("int + long = " + str(c))
}

test "float promotion" {
    int x = 5
    double y = 2.5
    double z = x + y
    assert(z == 7.5)
    println("int + double = " + str(z))
}

main {
    println("All new type tests passed!")
}
