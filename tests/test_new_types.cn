// Test new primitive types: long, double, byte, uint, ulong, ushort, ubyte

test "long type" {
    long x = 9999999999
    assert(x > 0)
    printin("long: {x}")
}

test "double type" {
    double pi = 3.14159265358979
    assert(pi > 3.0)
    printin("double: {pi}")
}

test "byte type" {
    byte b = 42
    assert(b == 42)
    printin("byte: {b}")
}

test "uint type" {
    uint u = 4294967295
    assert(u > 0)
    printin("uint: {u}")
}

test "ushort type" {
    ushort us = 65535
    assert(us > 0)
    printin("ushort: {us}")
}

test "ubyte type" {
    ubyte ub = 255
    assert(ub == 255)
    printin("ubyte: {ub}")
}

test "type arithmetic" {
    int a = 10
    long b = 20
    long c = a + b
    assert(c == 30)
    printin("int + long = {c}")
}

test "float promotion" {
    int x = 5
    double y = 2.5
    double z = x + y
    assert(z == 7.5)
    printin("int + double = {z}")
}

main {
    printin("All new type tests passed!")
}
