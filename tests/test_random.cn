import random

main {
    random.seed(42)
    int r1 = random.int(1, 100)
    int r2 = random.int(1, 100)
    int r3 = random.int(1, 100)
    printin(r1)
    printin(r2)
    printin(r3)

    float f = random.uniform(0.0, 1.0)
    if f >= 0.0 && f <= 1.0 {
        printin("uniform OK")
    }

    float g = random.gaussian()
    if g != 0.0 || g == 0.0 {
        printin("gaussian OK")
    }
}
