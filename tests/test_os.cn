// EXPECT: Windows
// EXPECT: 1
// EXPECT: hello
// EXPECT: 1
// EXPECT: true
import os

main {
    str name = os_os_name()
    printin(name)

    str cwd = os_get_cwd()
    printin(len(cwd) > 0)

    int pid = os_pid()
    printin(pid > 0)

    os_setenv("CNEXT_TEST", "hello")
    str val = os_getenv("CNEXT_TEST")
    printin(val)
    os_unsetenv("CNEXT_TEST")

    str home = os_home_dir()
    printin(home != "")

    bool ok = os_mkdir("_test_os_dir")
    printin(ok)
    if ok {
        os_rmdir("_test_os_dir")
    }
}
