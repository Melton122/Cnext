import encoding

main {
    str b64 = base64_encode("hello")
    printin(b64)

    str raw = base64_decode(b64)
    printin(raw == "hello")

    str hex = hex_encode("ABC")
    printin(hex)

    str dehex = hex_decode(hex)
    printin(dehex == "ABC")

    str url = url_encode("hello world")
    printin(url)

    str deurl = url_decode(url)
    printin(deurl == "hello world")
}
