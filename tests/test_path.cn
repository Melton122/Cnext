import path

main {
    str joined = path_join("foo", "bar")
    printin(joined)

    str dir = path_dirname("/foo/bar/file.txt")
    printin(dir)

    str base = path_basename("/foo/bar/file.txt")
    printin(base)

    str ext = path_extension("/foo/bar/file.txt")
    printin(ext)

    str norm = path_normalize("/foo/./bar/../baz/")
    printin(norm)
}
