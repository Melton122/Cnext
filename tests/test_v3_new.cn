import math

// ============================================================================
// Cnext v3.0 Feature Tests - New Features
// ============================================================================

// --- Test 1: Default Arguments ---
func greet(str name, str greeting = "Hello") {
    printin(greeting + ", " + name + "!")
}

func power(int base, int exp = 2) -> int {
    int result = 1
    for int i = 0; i < exp; i = i + 1 {
        result = result * base
    }
    return result
}

func test_default_args() {
    greet("World")
    greet("Alice", "Hi")
    printin(power(3) == 9)
    printin(power(2, 10) == 1024)
}

// --- Test 2: Named Arguments ---
func create_person(str name, int age, str city = "Unknown") {
    printin(name + " is " + age + " years old from " + city)
}

func test_named_args() {
    create_person(name = "Bob", age = 25, city = "NYC")
    create_person(age = 30, name = "Charlie")
}

// --- Test 3: Tuples ---
func test_tuples() {
    var t = (1, "hello", 3.14)
    printin(t)
}

// --- Test 4: Extension Methods ---
extend str {
    func shout() -> str {
        return self + "!!!"
    }
}

func test_extension_methods() {
    str msg = "Hello"
    printin(msg.shout() == "Hello!!!")
}

// --- Test 5: Optional/Result ---
func test_optional_result() {
    var opt = option(42)
    var res_ok = ok("success")
    var res_err = err("failure")
    printin(opt.tag == 1)
    printin(res_ok.tag == 0)
    printin(res_err.tag == 1)
}

// ============================================================================
// Main: Run all tests
// ============================================================================
main {
    printin("--- Test 1: Default Arguments ---")
    test_default_args()
    
    printin("--- Test 2: Named Arguments ---")
    test_named_args()
    
    printin("--- Test 3: Tuples ---")
    test_tuples()
    
    printin("--- Test 4: Extension Methods ---")
    test_extension_methods()
    
    printin("--- Test 5: Optional/Result ---")
    test_optional_result()
    
    printin("=== All v3 new feature tests completed ===")
}
