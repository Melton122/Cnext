import file
import io

main {
    str test_path = "test_file_output.txt"
    str copy_path = "test_file_copy.txt"

    // Create a test file using io.write_file
    io.write_file(test_path, "Hello from file module!")

    // file_exists
    bool exists = file.file_exists(test_path)
    printin(exists)

    // file_size
    var size = file.file_size(test_path)
    printin(size)

    // copy_file
    bool copied = file.copy_file(test_path, copy_path)
    printin(copied)

    // Read copied file to verify
    str copy_content = io.read_file(copy_path)
    printin(copy_content)

    // delete_file (original)
    bool deleted = file.delete_file(test_path)
    printin(deleted)

    // Verify original is gone
    bool gone = !file.file_exists(test_path)
    printin(gone)

    // Clean up copy too
    file.delete_file(copy_path)
}
