// EXPECT: 25
class Point {
    int x
    int y

    func new(int x_val, int y_val) {
        self.x = x_val
        self.y = y_val
    }

    func distance(Point other) -> int {
        int dx = self.x - other.x
        int dy = self.y - other.y
        return dx * dx + dy * dy
    }
}

main {
    Point p1 = new Point(0, 0)
    Point p2 = new Point(3, 4)

    printin(p1.distance(p2))
}
